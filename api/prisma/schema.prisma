// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

// UserRole was an enum — now stored as String to allow dynamic roles from UI
// Valid values are managed via Settings > บทบาท & สิทธิ์

enum DocStatus {
  draft    // แบบร่าง
  pending  // รออนุมัติ
  approved // อนุมัติแล้ว
  rejected // ปฏิเสธ
  cancelled // ยกเลิก
}

enum ApprovalAction {
  submit
  approve
  reject
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  initials     String   @default("")
  role         String   @default("sales")
  email               String?
  phone               String?
  department          String?
  position            String?
  firstName           String?
  lastName            String?
  firstNameEn         String?
  lastNameEn          String?
  lineUserId          String?
  signatureText       String?
  signatureUrl        String?
  active              Boolean  @default(true)
  mustChangePassword  Boolean  @default(false)
  docCounters         Json?    // { "mmyy": floorSeq } เช่น { "0626": 3 }
  createdAt           DateTime @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @db.Timestamptz(3)

  quotations       Quotation[]
  workOrders       WorkOrder[]
  workOrderCloseLogs WorkOrderCloseLog[]
  handOverJobs     HandOverJob[]
  purchaseRequests PurchaseRequest[]
  approvalLogs     ApprovalLog[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  sentEmailLogs    EmailLog[]
  customers        Customer[]
  workOrderPoAudits WorkOrderPoAudit[]
  refreshTokens    RefreshToken[]
  quotationCounters QuotationCounter[]
  workOrderReadLogs WorkOrderReadLog[]

  @@map("users")
}

model QuotationCounter {
  id        String   @id @default(cuid())
  salesId   String
  sales     User     @relation(fields: [salesId], references: [id], onDelete: Cascade)
  yy        String
  lastSeq   Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([salesId, yy])
  @@map("quotation_counters")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @db.Timestamptz(3)
  revokedAt DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// MASTER DATA
// ─────────────────────────────────────────────

model Customer {
  id            String   @id @default(cuid())
  salesId       String?
  sales         User?    @relation(fields: [salesId], references: [id])
  name          String
  contactPerson String?
  tel           String?
  email         String?
  address       String?
  taxId         String?
  type          String   @default("นิติบุคคล")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  quotations Quotation[]
  emailHistory EmailHistory[]

  @@map("customers")
}

model EmailHistory {
  id         String    @id @default(cuid())
  email      String
  name       String?
  lastUsedAt DateTime  @default(now()) @db.Timestamptz(3)
  useCount   Int       @default(1)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)

  @@unique([email, customerId])
  @@index([customerId])
  @@index([useCount, lastUsedAt])
  @@map("email_history")
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String?
  unit        String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  cost        Decimal  @default(0) @db.Decimal(12, 2)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@map("products")
}

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@map("units")
}

// ─────────────────────────────────────────────
// PR TYPE  (ประเภทใบขอซื้อ — แต่ละประเภทมีสายอนุมัติของตัวเอง)
// ─────────────────────────────────────────────
model PrType {
  id            String   @id @default(cuid())
  name          String   @unique
  // สายอนุมัติเฉพาะของประเภทนี้ เช่น [3,4,5,6]
  // ว่าง = ใช้สายอนุมัติ pr เริ่มต้นจาก settings.approvalFlowConfig
  approvalSteps Json     @default("[]")
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  purchaseRequests PurchaseRequest[]

  @@map("pr_types")
}

model Settings {
  id                  String   @id @default("main")
  companyName         String   @default("Green Dii Co., Ltd.")
  companyNameEn       String   @default("Green Dii Co., Ltd.")
  address             String   @default("")
  taxId               String   @default("")
  tel                 String   @default("")
  email               String   @default("")
  website             String   @default("")
  logoUrl             String   @default("")
  stepRoleConfig          Json?    // { "1":"sales", "2":"sale_mgr", ... }
  approvalFlowConfig      Json?    // { quotation:[1,2,3,4,5], workOrder:[3,4,5], pr:[3,4,5,6], handover:[3,4,5] }
  menuAccessConfig      Json?    // { quotations:['admin','sales',...], workorders:[...], ... }
  rolePermissionsConfig Json?    // { roles:[{key,label,description}], permissions:[{key,label,roles[]}] }
  updatedAt           DateTime @updatedAt @db.Timestamptz(3)

  @@map("settings")
}

// ─────────────────────────────────────────────
// QUOTATION
// ─────────────────────────────────────────────

model Quotation {
  id            String    @id @default(cuid())
  quoNo         String    @unique
  active        Boolean   @default(true)
  revisionNo    Int       @default(0)
  rootQuotationId String?
  rootQuotation Quotation? @relation("QuotationRevisions", fields: [rootQuotationId], references: [id])
  revisions     Quotation[] @relation("QuotationRevisions")
  salesId       String
  sales         User      @relation(fields: [salesId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String    // keep as text in case not in master
  attn          String?
  project       String
  address       String?
  tel           String?
  customerHp    String?
  conditionTerm String?
  validityDays  Int       @default(30)
  leadTime      String?
  paymentTerm   String?
  subTotal      Decimal   @default(0) @db.Decimal(12, 2)
  specialDiscount Decimal @default(0) @db.Decimal(12, 2)
  vat           Decimal   @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal   @default(0) @db.Decimal(12, 2)
  status        DocStatus @default(draft)
  approvalStep  Int       @default(0)
  remark        String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  items        QuotationItem[]
  workOrders   WorkOrder[]
  handOverJobs HandOverJob[]
  approvalLogs ApprovalLog[]
  attachments  Attachment[]
  emailLogs    EmailLog[]

  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  seq         Int       @default(0)
  desc        String
  note        String?   // free-form description / spec
  detailRows  Json?     // [{ desc, qty, unit, materialPrice, labourPrice, price, amount }]
  qty         Decimal   @default(0) @db.Decimal(10, 3)
  unit        String
  materialPrice Decimal @default(0) @db.Decimal(12, 2)
  labourPrice   Decimal @default(0) @db.Decimal(12, 2)
  price       Decimal   @default(0) @db.Decimal(12, 2)
  amount      Decimal   @default(0) @db.Decimal(12, 2)
  images      String[]  @default([])

  @@map("quotation_items")
}

// ─────────────────────────────────────────────
// WORK ORDER
// ─────────────────────────────────────────────

model WorkOrder {
  id             String    @id @default(cuid())
  woNo           String    @unique
  active         Boolean   @default(true)
  revisionNo     Int       @default(0)
  rootWorkOrderId String?
  rootWorkOrder  WorkOrder? @relation("WorkOrderRevisions", fields: [rootWorkOrderId], references: [id])
  revisions      WorkOrder[] @relation("WorkOrderRevisions")
  quotationId    String?
  quotation      Quotation? @relation(fields: [quotationId], references: [id])
  salesId        String
  sales          User      @relation(fields: [salesId], references: [id])
  project        String
  location       String?
  products       String?   // text description
  items          Json      @default("[]")
  responsibility String?
  customerName   String
  contactName    String?
  contactTel     String?
  teamAssignment String?
  qcDate         DateTime? @db.Timestamptz(3)
  installDate    DateTime? @db.Timestamptz(3)
  remark         String?
  docChecklist   Json      @default("{}")
  hasPo          Boolean   @default(false) @map("has_po")
  poAttachedDate DateTime? @map("po_attached_date") @db.Timestamptz(3)
  poStatus       String    @default("ยังไม่มี PO") @map("po_status")
  status         DocStatus @default(draft)
  approvalStep   Int       @default(0)
  isClosed       Boolean   @default(false)
  closedAt       DateTime? @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  handOverJobs     HandOverJob[]
  purchaseRequests PurchaseRequest[]
  approvalLogs     ApprovalLog[]
  attachments      Attachment[]
  poAuditLogs      WorkOrderPoAudit[]
  closeLogs        WorkOrderCloseLog[]
  emailLogs        EmailLog[]
  readLogs         WorkOrderReadLog[]

  @@map("work_orders")
}

model WorkOrderReadLog {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt      DateTime  @default(now()) @map("read_at") @db.Timestamptz(3)

  @@unique([workOrderId, userId])
  @@index([userId, readAt])
  @@index([workOrderId, readAt])
  @@map("work_order_read_logs")
}

model WorkOrderPoAudit {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  filename    String
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)

  @@index([workOrderId, createdAt])
  @@index([userId, createdAt])
  @@map("workorder_po_audits")
}

model WorkOrderCloseLog {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment     String?
  closedAt    DateTime  @default(now()) @db.Timestamptz(3)

  @@index([workOrderId, closedAt])
  @@index([userId, closedAt])
  @@map("workorder_close_logs")
}

// ─────────────────────────────────────────────
// HAND OVER JOB
// ─────────────────────────────────────────────

model HandOverJob {
  id             String     @id @default(cuid())
  hoNo           String     @unique
  quotationId    String?
  quotation      Quotation? @relation(fields: [quotationId], references: [id])
  workOrderId    String?
  workOrder      WorkOrder? @relation(fields: [workOrderId], references: [id])
  salesId        String
  sales          User       @relation(fields: [salesId], references: [id])
  project        String
  contractor     String?
  location       String?
  contactName    String?
  contactTel     String?
  product        String?
  items          Json       @default("[]")
  responsibility String?
  serviceDate    DateTime? @db.Timestamptz(3)
  qualityProduct Int        @default(0)
  qualitySales   Int        @default(0)
  qualityInstall Int        @default(0)
  comment        String?
  status         DocStatus  @default(draft)
  approvalStep   Int        @default(0)
  createdAt      DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime   @updatedAt @db.Timestamptz(3)

  attachments  Attachment[]
  approvalLogs ApprovalLog[]
  emailLogs    EmailLog[]

  @@map("hand_over_jobs")
}

// ─────────────────────────────────────────────
// PURCHASE REQUEST
// ─────────────────────────────────────────────

model PurchaseRequest {
  id           String     @id @default(cuid())
  prNo         String     @unique
  active       Boolean    @default(true)
  revisionNo   Int        @default(0)
  rootPurchaseRequestId String?
  rootPurchaseRequest PurchaseRequest? @relation("PurchaseRequestRevisions", fields: [rootPurchaseRequestId], references: [id])
  revisions    PurchaseRequest[] @relation("PurchaseRequestRevisions")
  workOrderId  String?
  workOrder    WorkOrder? @relation(fields: [workOrderId], references: [id])
  prTypeId     String?
  prType       PrType?    @relation(fields: [prTypeId], references: [id])
  salesId      String
  sales        User       @relation(fields: [salesId], references: [id])
  customer     String
  projectRef   String?
  dateIssue    DateTime? @db.Timestamptz(3)
  dateRequired DateTime? @db.Timestamptz(3)
  currency     String     @default("THB")
  subTotal        Decimal    @default(0) @db.Decimal(12, 2)
  specialDiscount Decimal    @default(0) @db.Decimal(12, 2)
  vat             Decimal    @default(0) @db.Decimal(12, 2)
  netTotal        Decimal    @default(0) @db.Decimal(12, 2)
  remarks         String?
  status       DocStatus  @default(draft)
  approvalStep Int        @default(0)
  createdAt    DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(3)

  items        PurchaseRequestItem[]
  approvalLogs ApprovalLog[]
  attachments  Attachment[]

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  seq               Int             @default(0)
  partNo            String?
  desc              String
  note              String?         // free-form description / spec
  qty               Decimal         @default(0) @db.Decimal(10, 3)
  unit              String
  price             Decimal         @default(0) @db.Decimal(12, 2)
  amount            Decimal         @default(0) @db.Decimal(12, 2)
  images            String[]        @default([])

  @@map("purchase_request_items")
}

// ─────────────────────────────────────────────
// APPROVAL LOG
// ─────────────────────────────────────────────

model ApprovalLog {
  id              String         @id @default(cuid())
  docType         String         // 'quotation' | 'workorder' | 'handover' | 'pr'
  quotationId     String?
  quotation       Quotation?     @relation(fields: [quotationId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id])
  handOverJobId   String?
  handOverJob     HandOverJob?   @relation(fields: [handOverJobId], references: [id])
  prId            String?
  pr              PurchaseRequest? @relation(fields: [prId], references: [id])
  approverId      String
  approver    User           @relation(fields: [approverId], references: [id])
  step        Int
  action      ApprovalAction
  comment     String?
  actedAt     DateTime       @default(now()) @db.Timestamptz(3)

  @@map("approval_logs")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@map("notifications")
}

model EmailLog {
  id            String     @id @default(cuid())
  workOrderId   String?
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])
  quotationId   String?
  quotation     Quotation? @relation(fields: [quotationId], references: [id])
  handOverJobId String?
  handOverJob   HandOverJob? @relation(fields: [handOverJobId], references: [id])
  sentById      String
  sentBy        User       @relation(fields: [sentById], references: [id])
  toRecipients  Json
  ccRecipients  Json?
  bccRecipients Json?
  subject       String
  bodyHtml      String
  bodyText      String?
  attachments   Json?
  status        String     @default("sent")
  errorMessage  String?
  sentAt        DateTime   @default(now()) @db.Timestamptz(3)
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)

  @@index([workOrderId])
  @@index([quotationId])
  @@index([handOverJobId])
  @@index([sentById])
  @@index([sentAt])
  @@map("email_logs")
}

// ─────────────────────────────────────────────
// ACTIVITY LOG
// ─────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username   String?  // snapshot ชื่อ user ณ เวลานั้น
  method     String   // GET POST PUT PATCH DELETE
  path       String   // /api/quotations/xxx
  statusCode Int      // 200 201 400 401 403 500
  ipAddress  String?
  userAgent  String?
  durationMs Int      // milliseconds
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@index([createdAt])
  @@index([statusCode])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// ATTACHMENT
// ─────────────────────────────────────────────

model Attachment {
  id              String           @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  category        String?
  poAmount        Decimal?         @db.Decimal(12, 2) @map("po_amount")
  fileUrl         String?
  quotationId     String?
  quotation       Quotation?       @relation(fields: [quotationId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder?       @relation(fields: [workOrderId], references: [id])
  handOverJobId   String?
  handOverJob     HandOverJob?     @relation(fields: [handOverJobId], references: [id])
  purchaseRequestId String?
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  uploadedAt      DateTime         @default(now()) @db.Timestamptz(3)

  @@map("attachments")
}
