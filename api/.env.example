# ===== DATABASE =====
DATABASE_URL="postgresql://greendii_app:your_password@localhost:5432/greendii_production"

# ===== JWT =====
JWT_SECRET="change-this-to-a-long-random-secret-string"
JWT_EXPIRES_IN="8h"

# ===== SERVER =====
PORT=4000
NODE_ENV=development

# ===== CORS =====
# Comma-separated origins for production, e.g.:
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:5500

# ===== FILE UPLOAD =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ===== LINE MESSAGING API (optional) =====
# สำหรับส่งแจ้งเตือนไปยัง LINE ของ User แต่ละคน
# 1. ไปที่ https://developers.line.biz/ → สร้าง Provider → สร้าง Messaging API channel
# 2. ไปที่ Messaging API → ออก Channel access token (long-lived)
# 3. เปิด webhook และตั้ง URL: https://yourdomain.com/api/line/webhook
# 4. ให้ User แต่ละคน Add LINE Bot ของคุณ → ระบบจะได้ lineUserId ของแต่ละคน
LINE_CHANNEL_ACCESS_TOKEN=

# ===== EMAIL / SMTP (optional) =====
# สำหรับส่งแจ้งเตือนทาง Email ของ User แต่ละคน
# Gmail: ใช้ App Password (ไม่ใช่ password login) — https://myaccount.google.com/apppasswords
# ต้องเปิด 2FA ก่อนถึงจะสร้าง App Password ได้
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=noreply@greendii.com
